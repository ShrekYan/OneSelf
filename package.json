{
  "name": "claude-blog-monorepo",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "packageManager": "npm@10.9.2",
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*"
  ],
  "overrides": {
    "react": "^19.2.3",
    "react-dom": "^19.2.3"
  },
  "scripts": {
    "build": "turbo build",
    "dev": "turbo dev",
    "lint": "turbo lint",
    "test": "turbo test",
    "prepare": "husky install"
  },
  "devDependencies": {
    "husky": "^8.0.3",
    "lint-staged": "^15.2.10",
    "prettier": "^3.3.3",
    "turbo": "^2.4.2"
  },
  "lint-staged": {
    "!(.claude)/**/*.{ts,tsx}": [
      "prettier --write",
      "eslint --fix",
      "eslint --max-warnings=0"
    ],
    "!(.claude)/**/*.{css,scss}": [
      "stylelint --fix"
    ]
  }
}
