{
  "$schema": "https://turborepo.org/schema.json",
  "globalDependencies": ["package-lock.json", ".env*"],
  "tasks": {
    "dev": {
      "cache": false
    },
    "build": {
      "dependsOn": ["^build"],
      "outputs": ["dist/**"]
    },
    "lint": {
      "outputs": []
    },
    "lint:staged": {
      "outputs": [],
      "cache": false
    },
    "test": {
      "outputs": []
    }
  }
}
