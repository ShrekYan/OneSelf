NODE_ENV=development
PORT=8890

# Application
APP_NAME=Log Service (Dev)
APP_VERSION=1.0.0

# Prisma MySQL database connection (if needed)
# DATABASE_URL="mysql://root@127.0.0.1:3306/log_db?connection_limit=10&pool_timeout=10&connect_timeout=5"

# Graylog configuration (for remote logging)
# GRAYLOG_ENABLED=false
# GRAYLOG_HOST=127.0.0.1
# GRAYLOG_PORT=12201
# GRAYLOG_INDEX=claude-logs

# File logging configuration
FILE_LOG_ENABLED=true
FILE_LOG_DIR=./logs
FILE_LOG_LEVEL=info

# CORS
ALLOWED_ORIGINS=*
