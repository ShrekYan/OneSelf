{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Bash(git push *)",
      "Bash(npm install *)",
      "Bash(npx prisma migrate *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm *)",
      "Bash(sudo *)"
    ],
    "defaultMode": "acceptEdits"
  },
  "enabledMcpjsonServers": [
    "figma"
  ],
  "enableAllProjectMcpServers": true
}
