{
  "permissions": {
    "allow": [
      "Read",
      "Write",
      "Edit",
      "Bash(git push *)",
      "Bash(npm install *)",
      "Bash(npx prisma migrate *)",
      "mcp__pixso__design_to_code"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(rm *)",
      "Bash(sudo *)"
    ],
    "defaultMode": "acceptEdits"
  },
  "enableAllProjectMcpServers": true,
  "enabledMcpjsonServers": [
    "figma"
  ]
}
