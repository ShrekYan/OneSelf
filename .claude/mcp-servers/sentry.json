{
  "mcpServers": {
    "sentry": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-sentry"
      ],
      "env": {
        "SENTRY_AUTH_TOKEN": "your_token_here",
        "SENTRY_ORG_SLUG": "your-org",
        "SENTRY_PROJECT_SLUG": "your-project"
      }
    }
  }
}